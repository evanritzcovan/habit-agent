# Copy to .env at repo root. Restart Expo after changes.

EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# Publishable (client) key from Supabase → Settings → API
EXPO_PUBLIC_SUPABASE_KEY=your-publishable-key

# Optional: Supabase CLI (only if you use a token instead of `npx supabase login`)
# SUPABASE_ACCESS_TOKEN=

# App config (optional)
# EXPO_PUBLIC_ENV=development
# EXPO_PUBLIC_ENABLE_LOGS=true

# Edge Function secrets go in the Supabase Dashboard, not here:
# OPENAI_API_KEY=
